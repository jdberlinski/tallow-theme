{
  "name": "tallow-theme",
  "main": "./extension.js",
  "activationEvents": ["onStartupFinished"],
  "displayName": "Tallow",
  "description": "A minimal, warm, distraction-free theme with dark and light variants.",
  "version": "0.0.2",
  "publisher": "jdberlinski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jdberlinski/tallow-theme"
  },
  "keywords": [
    "theme",
    "minimal",
    "dark",
    "light",
    "warm",
    "distraction-free"
  ],
  "galleryBanner": {
    "color": "#1d1b19",
    "theme": "dark"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Themes"
  ],
  "contributes": {
    "configuration": {
      "title": "Tallow",
      "properties": {
        "tallow.italicComments": {
          "type": "boolean",
          "default": true,
          "description": "Use italic font style for comments."
        },
        "tallow.boldOperators": {
          "type": "boolean",
          "default": false,
          "description": "Use bold font style for operators (e.g. <-, |>)."
        }
      }
    },
    "themes": [
      {
        "label": "Tallow Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/tallow-dark.json"
      },
      {
        "label": "Tallow Light",
        "uiTheme": "vs",
        "path": "./themes/tallow-light.json"
      }
    ]
  }
}
